NODE_ENV=development
PORT=5173

# Local SQLite and generated HTML/PDF files.
SLIDE_STUDIO_DATA_DIR=.local-data

# Optional: leave blank locally to use the built-in default.
FRONTEND_SLIDES_DIR=

# Optional AI provider defaults for the demo account.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_API_KEY=

# Portfolio demo account. Set SEED_DEMO=false to disable auto-seeding.
SEED_DEMO=true
DEMO_EMAIL=demo@slidestudio.local
DEMO_PASSWORD=demo1234

# PDF export. Leave blank locally unless Chrome is installed in a custom path.
CHROME_PATH=
